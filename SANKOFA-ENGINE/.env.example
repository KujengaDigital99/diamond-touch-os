# Copy to .env and fill in values. Never commit .env.
#
# ── AI Provider ───────────────────────────────────────────────────────────────
# The engine auto-detects the provider from whichever key is present.
# Set only ONE key. If both are set, set AI_PROVIDER to declare the winner.
#
# Option A — OpenAI (ChatGPT)
OPENAI_API_KEY=sk-...
#
# Option B — Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...
#
# Optional: override auto-detection
# AI_PROVIDER=openai   # or: anthropic

# ── Model overrides ───────────────────────────────────────────────────────────
# Leave blank to use provider defaults:
#   OpenAI    → gpt-4o-mini (standard)  /  gpt-4o (upgrade)
#   Anthropic → claude-haiku-4-5-20251001 (standard)  /  claude-sonnet-4-6 (upgrade)
#
# Override with an exact model name if needed:
# NOMMO_MODEL=
# OYA_MODEL=
# MAWU_MODEL=
# ESHU_MODEL=
# ANANSI_MODEL=
# ANANSI_RESEARCH_MODEL=   # upgrade tier — used for RESEARCH mode
# YEMOJA_MODEL=
# ELEGBA_MODEL=

# ── Watcher ────────────────────────────────────────────────────────────────────
WATCHER_BATCH_QUIET_MS=30000

# ── Buffer — social media scheduling ─────────────────────────────────────────
BUFFER_ACCESS_TOKEN=

# ── Email — add when credentials available ───────────────────────────────────
# SMTP_HOST=
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASS=
